{
  "name": "@dommaker/harness",
  "version": "0.7.1",
  "description": "通用工程约束框架 - 铁律系统、检查点验证、测试门控、拦截器",
  "keywords": [
    "harness",
    "constraint",
    "iron-law",
    "quality-gate",
    "engineering"
  ],
  "author": "kww",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "harness": "./bin/harness.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "require": "./dist/core/index.js",
      "import": "./dist/core/index.js"
    },
    "./presets": {
      "types": "./dist/presets/index.d.ts",
      "require": "./dist/presets/index.js",
      "import": "./dist/presets/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "templates",
    "github-actions"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kww/harness.git"
  },
  "bugs": {
    "url": "https://github.com/kww/harness/issues"
  },
  "homepage": "https://github.com/kww/harness#readme"
}
